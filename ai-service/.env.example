# ChainTrust AI Service Configuration

# MongoDB Connection (Required for tool data access)
MONGODB_URI=mongodb://localhost:27017/ChainTrust

# OpenAI Configuration (For LangChain Agent)
OPENAI_API_KEY=your_openai_api_key_here
# Alternative: OPENROUTER_API_KEY if using OpenRouter

# S3 / MinIO Configuration (For file reading and OCR)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1

# JWT Secret (For validating tokens during session init)
JWT_SECRET=your_jwt_secret_here

# App configuration
PORT=8000
DEBUG=True
