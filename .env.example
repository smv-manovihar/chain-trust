# Global Environment Variables for ChainTrust

# MongoDB
# Production: mongodb+srv://...
# Dev: mongodb://mongodb:27017/chaintrust
MONGODB_URI=mongodb://mongodb:27017/chaintrust

# Secrets
JWT_SECRET=your_jwt_secret_here
OPENAI_API_KEY=your_openai_api_key_here

# S3 / MinIO
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=chaintrust
S3_REGION=us-east-1
# Public URL for browser access (MinIO dev usually needs the IP of the host or localhost)
S3_PUBLIC_URL=http://localhost:9000/chaintrust

# Email (Optional)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# Google OAuth (Optional)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost/api/auth/google/callback

# Blockchain (Optional for root compose)
# NEXT_PUBLIC_RPC_URL can be set in frontend environment
